{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"files": {
		"includes": ["src/**/*.ts", "*.json"],
		"ignoreUnknown": true,
		"experimentalScannerIgnores": [
			".agents",
			".claude",
			".github",
			".gitnexus",
			".omp",
			".opencode",
			".pi",
			"dist",
			"node_modules",
			"*.lock",
			"templates"
		]
	}
}
