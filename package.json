{
	"name": "guardian-cli",
	"version": "0.1.0",
	"description": "Token-optimized agentic framework scaffolder",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"guardian-cli": "./dist/index.js"
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target bun",
		"test": "bun test",
		"lint": "biome check .",
		"format": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"dev": "bun run src/index.ts"
	},
	"dependencies": {
		"@clack/prompts": "^0.7.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "latest",
		"typescript": "^5.0.0"
	},
	"keywords": ["cli", "agentic", "framework", "ai", "scaffold"],
	"author": "",
	"license": "MIT"
}
