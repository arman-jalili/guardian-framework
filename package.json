{
  "name": "guardian-cli",
  "version": "0.1.0",
  "description": "Token-optimized agentic framework scaffolder",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "guardian-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "biome": "^0.4.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "cli",
    "agentic",
    "framework",
    "ai",
    "scaffold"
  ],
  "author": "",
  "license": "MIT"
}